# SiteLedger Environment Variables
# Copy this file to .env and fill in your values

# JWT Secret — change this to a long random string
JWT_SECRET=change-this-to-a-long-random-secret-string-12345

# Port the server runs on
PORT=5000

# Frontend URL (for CORS) — change if your React app runs on a different port
FRONTEND_URL=http://localhost:3000
